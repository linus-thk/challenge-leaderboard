<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lastprognose-Challenge SoSe26 — Leaderboard</title>
  {% if plotlyjs %}<script>{{ plotlyjs | safe }}</script>{% endif %}
  <style>
    :root {
      --bg: #f4f6f9;
      --card: #ffffff;
      --ink: #1a1f29;
      --muted: #6b7280;
      --line: #e7eaef;
      --accent: #4f46e5;
      --accent-soft: #eef2ff;
      --gold: #f6c453;
      --shadow: 0 1px 3px rgba(16, 24, 40, .06), 0 1px 2px rgba(16, 24, 40, .04);
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial,
                   sans-serif;
      max-width: 1100px; margin: 0 auto; padding: 2rem 1.25rem 4rem;
      color: var(--ink); background: var(--bg); line-height: 1.5;
    }
    a { color: var(--accent); }
    .hero {
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
      color: #fff; border-radius: 16px; padding: 1.75rem 2rem;
      box-shadow: var(--shadow); margin-bottom: 1.5rem;
    }
    .hero-top { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
                margin-bottom: .35rem; }
    .hero-logo { height: 52px; width: auto; background: #fff; border-radius: 10px;
                 padding: 7px 10px; box-shadow: 0 1px 4px rgba(0, 0, 0, .15); }
    .hero h1 { margin: 0; font-size: 1.8rem; letter-spacing: -.01em; }
    .hero p { margin: 0; color: rgba(255, 255, 255, .88); max-width: 70ch; }
    .hero .stats { margin-top: 1.1rem; display: flex; gap: 2rem; flex-wrap: wrap; }
    .hero .stat b { display: block; font-size: 1.5rem; line-height: 1.1; }
    .hero .stat span { font-size: .8rem; color: rgba(255, 255, 255, .8);
                       text-transform: uppercase; letter-spacing: .04em; }
    .meta { color: var(--muted); font-size: .9rem; }
    .card {
      background: var(--card); border: 1px solid var(--line);
      border-radius: 14px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
      box-shadow: var(--shadow);
    }
    .card > h2 { margin: 0 0 .9rem; font-size: 1.2rem; }
    .card > .meta { margin: -.4rem 0 1rem; }
    .js-plotly-plot { width: 100% !important; }
    table { border-collapse: collapse; width: 100%; }
    th, td { padding: .55rem .8rem; text-align: left;
             border-bottom: 1px solid var(--line); }
    th { background: #fafbfc; font-size: .82rem; text-transform: uppercase;
         letter-spacing: .03em; color: var(--muted); }
    td.num { text-align: right; font-variant-numeric: tabular-nums; }
    tbody tr:nth-child(even) td { background: #fcfcfd; }
    /* Gesamtbester (Zeile 1) nur in der Haupt-Rangliste hervorheben. */
    table.ranking tbody tr:first-child td { font-weight: 600; }
    table.ranking tbody tr:first-child td:first-child::before { content: "🏆 "; }
    td.locf { color: #9aa1ab; }
    td.miss { color: #d0d4da; text-align: right; }
    /* Tagesbester je Spalte in „Tagesfehler je Team". */
    td.best { font-weight: 700; }
    .empty { color: #888; font-style: italic; padding: 2rem 0; text-align: center; }
    /* Kalender-Datumswahl fürs Forecast-Chart — permanent geöffnet,
       rechts neben dem Plot (auf schmalen Screens darunter umbrechend);
       eigener Flex-Bereich, überlappt den Plot nie. */
    .fig-cal-row { display: flex; align-items: flex-start; gap: 1.1rem;
                   flex-wrap: wrap; }
    .fig-cal-plot { flex: 1 1 480px; min-width: 0; }
    .cal-wrap { flex: 0 0 auto; }
    .cal {
      padding: .8rem .9rem; width: max-content;
      background: var(--card); border: 1px solid var(--line);
      border-radius: 12px; box-shadow: var(--shadow);
    }
    .cal-sel {
      margin: 0 0 .6rem; padding: .35rem .6rem; text-align: center;
      font-weight: 600; font-size: .9rem; color: var(--accent);
      background: var(--accent-soft); border-radius: 8px;
    }
    .cal-head { display: flex; align-items: center; justify-content: space-between;
                gap: .5rem; margin-bottom: .55rem; }
    .cal-title { font-weight: 600; font-size: .95rem; min-width: 9.5rem;
                 text-align: center; }
    .cal-nav {
      width: 30px; height: 30px; font: inherit; line-height: 1;
      color: var(--ink); background: none; border: 1px solid var(--line);
      border-radius: 8px; cursor: pointer;
    }
    .cal-nav:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
    .cal-nav:disabled { opacity: .3; cursor: default; }
    .cal-grid { display: grid; grid-template-columns: repeat(7, 38px); gap: 3px; }
    .cal-dow { text-align: center; font-size: .7rem; color: var(--muted);
               text-transform: uppercase; letter-spacing: .03em; padding: .15rem 0; }
    .cal-day {
      height: 34px; font: inherit; font-size: .85rem; text-align: center;
      color: #c6cbd3; background: none; border: none; border-radius: 9px;
    }
    .cal-day.avail { color: var(--ink); background: var(--accent-soft);
                     font-weight: 600; cursor: pointer; }
    .cal-day.avail:hover { outline: 2px solid var(--accent); outline-offset: -1px; }
    .cal-day.sel { background: var(--accent); color: #fff; }
    .rank-badge { display: inline-block; min-width: 1.5rem; text-align: center;
                  font-weight: 600; }
    footer { color: var(--muted); font-size: .88rem; margin-top: 2rem;
             text-align: center; }
  </style>
</head>
<body>
  <header class="hero">
    <div class="hero-top">
      {% if logo_uri %}<img class="hero-logo" src="{{ logo_uri }}" alt="SpotOptim">{% endif %}
      <h1>Lastprognose-Challenge SoSe26</h1>
    </div>
    <p>
      DE-Day-Ahead-Lastprognose im Wettbewerb: bewertet über die mittlere
      MAE aller Zieltage (aufsteigend; fehlende Submissions werden per LOCF
      aus der jeweils letzten Prognose fortgeschrieben).
    </p>
    {% if rows %}
    <div class="stats">
      <div class="stat"><b>{{ rows|length }}</b><span>Teams</span></div>
      <div class="stat"><b>{{ daily.dates|length if daily and daily.dates else 0 }}</b><span>Bewertete Tage</span></div>
      <div class="stat"><b>{{ "%.0f"|format(rows[0].mean_mae) }}</b><span>Beste Ø MAE [MW]</span></div>
    </div>
    {% endif %}
  </header>

  <p class="meta">Stand: {{ generated_at }} UTC.</p>

  <section class="card">
    <h2>Leaderboard</h2>
    {% if rows %}
    <table class="ranking">
      <thead>
        <tr>
          <th>#</th><th>Team</th>
          <th class="num">Mean MAE [MW]</th>
          <th class="num">Sum MAE [MW]</th>
          <th class="num">Bewertete Tage</th>
        </tr>
      </thead>
      <tbody>
      {% for row in rows %}
        <tr>
          <td><span class="rank-badge">{{ row.rank }}</span></td>
          <td>{{ row.display_name }}</td>
          <td class="num">{{ "%.2f"|format(row.mean_mae) }}</td>
          <td class="num">{{ "%.2f"|format(row.sum_mae) }}</td>
          <td class="num">{{ row.n_submissions }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
      <p class="empty">Noch keine bewerteten Submissions.</p>
    {% endif %}
  </section>

  {% if figs and figs.forecast %}
  <section class="card">
    <h2>Prognose vs. Ist-Last</h2>
    <p class="meta">
      Stündliche 24-h-Prognose jedes Teams gegen die tatsächlich gemessene
      Netzlast (ENTSO-E Actual Total Load, DE). Die gestrichelte Linie ist die
      ENTSO-E-Day-ahead-Prognose als Referenz-Baseline. Zieltag über den
      Kalender wählbar.
    </p>
    <div class="fig-cal-row">
      <div class="fig-cal-plot">{{ figs.forecast | safe }}</div>
      <div class="cal-wrap" id="cal-forecast" hidden>
        <div class="cal" id="cal-forecast-panel" role="group" aria-label="Zieltag wählen">
          <p class="cal-sel">Zieltag: <span id="cal-forecast-sel"></span></p>
          <div class="cal-head">
            <button type="button" class="cal-nav" id="cal-forecast-prev"
                    aria-label="Voriger Monat">‹</button>
            <span class="cal-title" id="cal-forecast-title"></span>
            <button type="button" class="cal-nav" id="cal-forecast-next"
                    aria-label="Nächster Monat">›</button>
          </div>
          <div class="cal-grid" id="cal-forecast-grid"></div>
        </div>
      </div>
    </div>
    <script>
    (function () {
      "use strict";
      var MONTHS = ["Januar", "Februar", "März", "April", "Mai", "Juni", "Juli",
                    "August", "September", "Oktober", "November", "Dezember"];
      var DOWS = ["Mo", "Di", "Mi", "Do", "Fr", "Sa", "So"];
      var tries = 0;

      function init() {
        var gd = document.getElementById("fig-forecast");
        if (!gd || !gd.layout || !gd.layout.meta) {
          if (tries++ < 100) { setTimeout(init, 50); }
          return;
        }
        var meta = gd.layout.meta;
        var days = meta.days || [];
        if (days.length < 2) { return; }  // nichts zu wählen

        var wrap = document.getElementById("cal-forecast");
        var selLabel = document.getElementById("cal-forecast-sel");
        var title = document.getElementById("cal-forecast-title");
        var grid = document.getElementById("cal-forecast-grid");
        var prev = document.getElementById("cal-forecast-prev");
        var next = document.getElementById("cal-forecast-next");

        var avail = {};
        days.forEach(function (d) { avail[d] = true; });
        var selected = days[days.length - 1];
        var view = { y: +selected.slice(0, 4), m: +selected.slice(5, 7) - 1 };
        var minKey = days[0].slice(0, 7), maxKey = days[days.length - 1].slice(0, 7);

        function monthKey(y, m) {
          return y + "-" + String(m + 1).padStart(2, "0");
        }

        function selectDay(d) {
          selected = d;
          var traces = meta.dayTraces[d] || [];
          var vis = gd.data.map(function (_, i) {
            return traces.indexOf(i) !== -1;
          });
          Plotly.update(gd, { visible: vis },
                        { "title.text": meta.titlePrefix + " — " + d });
          selLabel.textContent = d;
          renderGrid();
        }

        function renderGrid() {
          title.textContent = MONTHS[view.m] + " " + view.y;
          prev.disabled = monthKey(view.y, view.m) <= minKey;
          next.disabled = monthKey(view.y, view.m) >= maxKey;
          grid.textContent = "";
          DOWS.forEach(function (n) {
            var el = document.createElement("span");
            el.className = "cal-dow";
            el.textContent = n;
            grid.appendChild(el);
          });
          var first = new Date(Date.UTC(view.y, view.m, 1));
          var offset = (first.getUTCDay() + 6) % 7;  // Mo = 0
          var nDays = new Date(Date.UTC(view.y, view.m + 1, 0)).getUTCDate();
          for (var i = 0; i < offset; i++) {
            grid.appendChild(document.createElement("span"));
          }
          for (var day = 1; day <= nDays; day++) {
            var iso = monthKey(view.y, view.m) + "-" + String(day).padStart(2, "0");
            var btn = document.createElement("button");
            btn.type = "button";
            btn.className = "cal-day";
            btn.textContent = day;
            if (avail[iso]) {
              btn.classList.add("avail");
              if (iso === selected) { btn.classList.add("sel"); }
              btn.addEventListener("click", selectDay.bind(null, iso));
            } else {
              btn.disabled = true;
            }
            grid.appendChild(btn);
          }
        }

        function shiftMonth(delta) {
          var d = new Date(Date.UTC(view.y, view.m + delta, 1));
          view = { y: d.getUTCFullYear(), m: d.getUTCMonth() };
          renderGrid();
        }

        prev.addEventListener("click", shiftMonth.bind(null, -1));
        next.addEventListener("click", shiftMonth.bind(null, 1));

        selLabel.textContent = selected;
        renderGrid();
        wrap.hidden = false;
        // Der Plot wurde in voller Kartenbreite gerendert, bevor der
        // Kalender eingeblendet wurde — auf die schmalere Flex-Spalte
        // nachjustieren (responsive greift sonst erst beim Window-Resize).
        Plotly.Plots.resize(gd);
      }

      init();
    })();
    </script>
  </section>
  {% endif %}

  {% if figs and figs.leaderboard %}
  <section class="card">
    <h2>Mittlere MAE je Team</h2>
    {{ figs.leaderboard | safe }}
  </section>
  {% endif %}

  {% if figs and figs.mae_time %}
  <section class="card">
    <h2>MAE-Verlauf</h2>
    <p class="meta">
      Tages-MAE je Team über die Zeit. Offene Marker kennzeichnen via LOCF
      fortgeschriebene Tage (keine frische Submission).
    </p>
    {{ figs.mae_time | safe }}
  </section>
  {% endif %}

  {% if daily and daily.dates %}
  <section class="card">
    <h2>Tagesfehler je Team</h2>
    <p class="meta">
      MAE [MW] pro Zieltag. <b>Fett</b> markiert den besten Wert des Tages
      (Spaltenminimum). Werte in <span class="locf">grau</span> kennzeichnen
      eine via LOCF fortgeschriebene Prognose (keine frische Submission für
      diesen Tag); ein Strich bedeutet, dass für das Team kein scoreable
      Forecast vorlag.
    </p>
    <table>
      <thead>
        <tr>
          <th>Team</th>
          {% for d in daily.dates %}<th class="num">{{ d }}</th>{% endfor %}
        </tr>
      </thead>
      <tbody>
      {% for team in daily.teams %}
        <tr>
          <td>{{ team.display_name }}</td>
          {% for c in team.cells %}
            {% if c.mae is none %}
              <td class="miss">—</td>
            {% else %}
              <td class="num{{ ' locf' if c.carried else '' }}{{ ' best' if c.best else '' }}"{% if c.carried %} title="LOCF — fortgeschrieben"{% endif %}>{{ "%.2f"|format(c.mae) }}</td>
            {% endif %}
          {% endfor %}
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <footer>
    Daten: <a href="data/scores.json">scores.json</a>,
    <a href="data/daily.json">daily.json</a> (Tagesfehler pro Team).
    Spielregeln: Kapitel 12 des Skripts. Bewertungs-Pipeline:
    <a href="https://github.com/bartzbeielstein/challenge-leaderboard">challenge-leaderboard</a>.
  </footer>
</body>
</html>
